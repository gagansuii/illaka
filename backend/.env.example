# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/illaka_db
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
# CORS_ORIGINS=["http://localhost:3000","https://yourfrontend.com"]

# ─── JWT Auth ───────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Redis (optional — in-memory LRU fallback if not set) ───────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ─── Razorpay (legacy) ──────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# RAZORPAY_UPI_VPA=merchant@upi

# ─── Pricing (smallest currency unit — paise for INR) ───────────────────────
SUBSCRIPTION_PRICE=49900
HOSTING_FEE_AMOUNT=25000
PROMOTION_PRICE=15000
HOSTING_FEE_THRESHOLD=50

# ─── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Pinecone ───────────────────────────────────────────────────────────────
# PINECONE_API_KEY=...
# PINECONE_INDEX=ilaka-events

# ─── Email (Gmail SMTP) ─────────────────────────────────────────────────────
# EMAIL_USER=your@gmail.com
# EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_FROM_NAME=Illaka
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ─── Geolocation ────────────────────────────────────────────────────────────
# IPINFO_TOKEN=your_ipinfo_token

# ─── Cron / Internal secrets ────────────────────────────────────────────────
# CRON_SECRET=your_cron_secret
# HEALTH_SECRET=your_health_secret
