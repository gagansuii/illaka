// Prisma schema for Ilaaka

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

enum Role {
  USER
  ORGANIZER
  ADMIN
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum EventType {
  PHYSICAL
  ONLINE
}

enum LinkShareMode {
  IMMEDIATE
  BEFORE_EVENT
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String
  role             Role     @default(USER)
  emailVerified    Boolean  @default(false)
  latitude         Float?
  longitude        Float?
  radiusPreference Int      @default(5000)
  subscriptionType String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  events                  Event[]  @relation("OrganizerEvents")
  rsvps                   RSVP[]
  likes                   Like[]
  shares                  Share[]
  attendance              Attendance[]
  subscriptions           Subscription[]
  payments                Payment[]
  passwordResets          PasswordResetToken[]
  reminderLogs            ReminderLog[]
  emailVerificationTokens EmailVerificationToken[]
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String
  bannerUrl   String
  badgeIcon   String
  latitude    Float
  longitude   Float
  location    Unsupported("geography")
  startTime   DateTime
  endTime     DateTime
  visibility  Visibility  @default(PUBLIC)
  capacity    Int
  organizerId   String
  isPaid        Boolean       @default(false)
  ticketPrice   Int?
  engagementScore Int         @default(0)
  paymentQrUrl  String?
  address       String?
  shareToken    String?       @unique
  eventType     EventType?    @default(PHYSICAL)
  onlineLink    String?
  linkShareMode LinkShareMode?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizer   User        @relation("OrganizerEvents", fields: [organizerId], references: [id])
  rsvps       RSVP[]
  likes       Like[]
  shares      Share[]
  attendance  Attendance[]
  payments    Payment[]
  reminderLogs ReminderLog[]

  @@index([location], type: Gist)
  @@index([organizerId])
  @@index([visibility])
  @@index([startTime])
  @@index([engagementScore])
}

model RSVP {
  id        String   @id @default(uuid())
  ticketId  String   @default(uuid()) @unique
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Share {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([eventId])
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  status    String
  plan      String
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Payment {
  id            String   @id @default(uuid())
  userId        String
  eventId       String?
  provider      String
  providerRef   String
  amount        Int
  currency      String
  status        String
  reason        String
  createdAt     DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([eventId])
  @@index([providerRef])
  @@index([status])
}

model ReminderLog {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  type      String   // "6h" | "1h" | "1d"
  sentAt    DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, type])
}
