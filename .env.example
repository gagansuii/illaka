# Database connection (Prisma will also use SHADOW_DATABASE_URL for migrations)
# For a typical local Postgres/PostGIS setup, keep sslmode=disable.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ilaka_events?schema=public&sslmode=disable"
SHADOW_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ilaka_shadow?schema=public&sslmode=disable"

# Required on Vercel/pooled connections — set to the direct (non-pooler) connection string.
# For Supabase: use the "Direct connection" URL (port 5432, not 6543).
# For local dev, this can be the same as DATABASE_URL.
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ilaka_events?schema=public&sslmode=disable"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="some-long-random-string"

# Redis (optional; leave blank unless a Redis server is actually running)
REDIS_URL=""

# OpenAI / Pinecone (optional features)
OPENAI_API_KEY=""
PINECONE_API_KEY=""
PINECONE_INDEX="ilaka-events"

# Razorpay (payments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional IP geolocation fallback
IPINFO_TOKEN=""

# Pricing defaults (paise)
NEXT_PUBLIC_SUBSCRIPTION_PRICE="49900"
NEXT_PUBLIC_HOSTING_FEE_THRESHOLD="50"
NEXT_PUBLIC_HOSTING_FEE_AMOUNT="25000"
NEXT_PUBLIC_PROMOTION_PRICE="15000"

# Email (Nodemailer + Gmail SMTP — get app password at myaccount.google.com/apppasswords)
EMAIL_USER=""
EMAIL_APP_PASSWORD=""

# Cron job authentication — Vercel passes this automatically as Bearer token to cron routes
CRON_SECRET=""
